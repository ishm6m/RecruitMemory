# Copy this file to ".env" and fill in real values. NEVER commit the real .env.

# --- Qwen Cloud (OpenAI-compatible API) ---
# Get this key from the Qwen/DashScope console after you create an account.
QWEN_API_KEY=sk-your-qwen-key-here
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen-plus
QWEN_EMBED_MODEL=text-embedding-v3
# Speech-to-text for live interview capture. Uses the same key and base URL;
# set QWEN_ASR_BASE_URL only if your key has ASR enabled on a different endpoint.
QWEN_ASR_MODEL=qwen3-asr-flash

# --- Alibaba Cloud OSS (only needed for the backup script, Step 9) ---
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_ENDPOINT=https://oss-ap-southeast-1.aliyuncs.com
